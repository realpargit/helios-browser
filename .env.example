# Copy this file to `.env` and fill in real values. `.env` is gitignored —
# never commit it. Real secrets must come from your local environment or
# from CI secret stores, never from the repo.

# Google OAuth client ID (required for sign-in). Without it, auth:signIn
# is a no-op. Get one from https://console.cloud.google.com/apis/credentials
# under "OAuth 2.0 Client IDs" → Desktop app.
GOOGLE_CLIENT_ID=

# Optional: enable extra dev tooling (bench, debug logs). Has no effect in
# packaged builds — those tree-shake dev code at build time.
# NODE_ENV=development
